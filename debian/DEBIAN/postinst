#!/bin/bash
set -e

# 升级 Pillow（transformers 依赖）
pip3 install --user --upgrade Pillow || true

# 安装 Python 依赖
pip3 install --user dashscope pynput faster-whisper huggingface-hub deepmultilingualpunctuation || true

# 清理旧版 pycache，确保加载最新代码
find /usr/share/voice-typing -type d -name "__pycache__" -exec rm -rf {} + 2>/dev/null || true

# 创建配置目录
mkdir -p ~/.config/voice_typing

# uinput udev 规则：允许 plugdev 组访问 /dev/uinput
# pynput Controller 通过 uinput 模拟键盘事件，Electron/Chromium 应用需要
if [ ! -f /etc/udev/rules.d/99-voice-typing-uinput.rules ]; then
    echo 'KERNEL=="uinput", MODE="0660", GROUP="plugdev"' > /etc/udev/rules.d/99-voice-typing-uinput.rules
    udevadm control --reload-rules 2>/dev/null || true
    udevadm trigger --subsystem-match=misc 2>/dev/null || true
fi

echo "VoiceType 安装完成！"
echo "使用命令 'voice-typing' 启动应用"
echo "注意：如果首次安装，请注销重新登录以使 uinput 权限生效"
